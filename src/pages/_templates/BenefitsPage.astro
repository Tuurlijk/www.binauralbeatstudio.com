---
import Layout from '../../layouts/Layout.astro';
import { benefitCards } from '../../data/benefits';
import { loadTranslations, t, getLocalizedHashLink } from '../../utils/i18n';
import type { Locale } from '../../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);
const base = import.meta.env.BASE_URL;

const pageTitle = t('aboutBinauralBeats.benefits.title', locale, translations);
const pageDescription = t('aboutBinauralBeats.research.findings', locale, translations);

const relatedFrequencies: Record<string, string[]> = {
	benefit1: ['frequencyAlpha', 'frequencyTheta'],
	benefit2: ['frequencyBeta', 'frequencyGamma'],
	benefit3: ['frequencyDelta', 'frequencyTheta'],
	benefit4: ['frequencyTheta', 'frequencyAlpha'],
	benefit5: ['frequencyAlpha', 'frequencyGamma'],
	benefit6: ['frequencyAlpha', 'frequencyTheta'],
};
---

<Layout title={pageTitle} description={pageDescription}>
	<section class="benefits-page" aria-labelledby="benefits-page-heading">
		<div class="benefits-page__inner">
			<header class="benefits-page__header">
				<a class="benefits-page__back" href={getLocalizedHashLink('#benefits', locale)}>
					{t('screenshots.backHome', locale, translations)}
				</a>
				<h1 id="benefits-page-heading">{pageTitle}</h1>
				<p>{pageDescription}</p>
			</header>

			<div class="benefits-page__nav" aria-label={t('nav.benefits', locale, translations)}>
				{benefitCards.map((benefit) => (
					<a href={`#${benefit.slug}`}>
						{t(`aboutBinauralBeats.benefits.${benefit.id}.title`, locale, translations)}
					</a>
				))}
			</div>

			<div class="benefits-page__sections">
				{benefitCards.map((benefit) => (
					<section
						id={benefit.slug}
						class="benefits-page__section"
						style={`--benefit-panel: ${benefit.panel}; --benefit-title: ${benefit.title};`}
					>
						<div class="benefits-page__visual">
							<picture>
								<source srcset={`${base}images/benefits/${benefit.visual.replace('.png', '.webp')}`} type="image/webp" />
								<img
									src={`${base}images/benefits/${benefit.visual}`}
									alt=""
									width="640"
									height="640"
									loading="lazy"
								/>
							</picture>
						</div>

						<div class="benefits-page__copy">
							<picture>
								<source srcset={`${base}images/benefits/${benefit.symbol.replace('.png', '.webp')}`} type="image/webp" />
								<img
									class="benefits-page__symbol"
									src={`${base}images/benefits/${benefit.symbol}`}
									alt=""
									width="42"
									height="42"
									loading="lazy"
									aria-hidden="true"
								/>
							</picture>
							<h2>{t(`aboutBinauralBeats.benefits.${benefit.id}.title`, locale, translations)}</h2>
							<p>{t(`aboutBinauralBeats.benefits.${benefit.id}.description`, locale, translations)}</p>
							<p>{t('aboutBinauralBeats.howItWorks.personalization', locale, translations)}</p>

							<div class="benefits-page__frequencies">
								<h3>{t('aboutBinauralBeats.howItWorks.frequencyIntro', locale, translations)}</h3>
								<ul>
									{relatedFrequencies[benefit.id].map((frequencyKey) => (
										<li>{t(`aboutBinauralBeats.howItWorks.${frequencyKey}`, locale, translations)}</li>
									))}
								</ul>
							</div>
						</div>
					</section>
				))}
			</div>
		</div>
	</section>
</Layout>

<style>
	.benefits-page {
		padding: clamp(8rem, 12vw, 10rem) 1rem clamp(4.5rem, 8vw, 7rem);
	}

	.benefits-page__inner {
		margin: 0 auto;
		max-width: 76rem;
	}

	.benefits-page__header {
		margin: 0 auto clamp(2.6rem, 5vw, 4rem);
		max-width: 62rem;
		text-align: center;
	}

	.benefits-page__back {
		color: var(--accent);
		display: inline-flex;
		font-family: var(--font-body);
		font-size: clamp(1rem, 0.9rem + 0.25vw, 1.15rem);
		font-weight: var(--font-weight-ui);
		margin-bottom: 1.2rem;
		text-decoration: none;
	}

	.benefits-page__back:hover {
		color: var(--primary);
	}

	.benefits-page h1 {
		color: var(--text-primary);
		font-size: clamp(3.8rem, 3rem + 2vw, 5.5rem);
		margin: 0 0 0.75rem;
	}

	.benefits-page__header p {
		color: var(--text-secondary);
		font-size: clamp(1.18rem, 1rem + 0.45vw, 1.5rem);
		line-height: 1.25;
		margin: 0 auto;
	}

	.benefits-page__nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		justify-content: center;
		margin-bottom: clamp(2.2rem, 5vw, 4rem);
	}

	.benefits-page__nav a {
		border: 1px solid var(--border-light);
		border-radius: 999px;
		color: var(--text-secondary);
		font-family: var(--font-body);
		font-size: 1rem;
		font-weight: var(--font-weight-ui);
		line-height: 1;
		padding: 0.62rem 0.9rem;
		text-decoration: none;
	}

	.benefits-page__nav a:hover {
		background: rgba(244, 95, 17, 0.08);
		border-color: rgba(244, 95, 17, 0.42);
		color: var(--accent);
	}

	.benefits-page__sections {
		display: grid;
		gap: clamp(1.3rem, 3vw, 2rem);
	}

	.benefits-page__section {
		background: var(--benefit-panel);
		border-radius: 2rem;
		color: #fff;
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
		overflow: hidden;
		scroll-margin-top: 7rem;
	}

	.benefits-page__visual {
		min-height: 24rem;
	}

	.benefits-page__visual picture,
	.benefits-page__visual img {
		display: block;
		height: 100%;
		width: 100%;
	}

	.benefits-page__visual img {
		object-fit: cover;
	}

	.benefits-page__copy {
		display: grid;
		align-content: center;
		padding: clamp(1.6rem, 3vw, 2.8rem);
	}

	.benefits-page__symbol {
		height: 2.75rem;
		margin-bottom: 1.2rem;
		object-fit: contain;
		width: 2.75rem;
	}

	.benefits-page h2 {
		color: var(--benefit-title);
		font-size: clamp(2.4rem, 1.9rem + 1.2vw, 3.6rem);
		line-height: 0.86;
		margin: 0 0 1rem;
	}

	.benefits-page h3 {
		color: rgba(255, 255, 255, 0.9);
		font-family: var(--font-body);
		font-size: clamp(1.2rem, 1.05rem + 0.35vw, 1.45rem);
		font-weight: var(--font-weight-card-title);
		margin: 0 0 0.6rem;
	}

	.benefits-page__copy p,
	.benefits-page li {
		font-family: var(--font-copy);
		font-size: clamp(1.18rem, 1.02rem + 0.45vw, 1.5rem);
		font-weight: var(--font-weight-body);
		line-height: 1.16;
	}

	.benefits-page__copy p {
		margin: 0 0 1rem;
	}

	.benefits-page__frequencies {
		border-top: 1px solid rgba(255, 255, 255, 0.28);
		margin-top: 0.6rem;
		padding-top: 1.1rem;
	}

	.benefits-page ul {
		display: grid;
		gap: 0.55rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.benefits-page li {
		color: rgba(255, 255, 255, 0.84);
	}

	@media (max-width: 820px) {
		.benefits-page__section {
			grid-template-columns: 1fr;
		}

		.benefits-page__visual {
			min-height: 18rem;
		}
	}
</style>

