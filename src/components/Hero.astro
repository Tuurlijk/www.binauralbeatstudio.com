---
import { loadTranslations, t, getLocalizedHashLink } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);
const base = import.meta.env.BASE_URL;
---

<section
	id="hero"
	class="hero-section px-4 sm:px-6 lg:px-8"
	style={`--hero-bg-image: image-set(url("${base}images/hero/header-background.webp") type("image/webp"), url("${base}images/hero/header-background.png") type("image/png")); --hero-circle-image: image-set(url("${base}images/hero/header-symbol-circle.webp") type("image/webp"), url("${base}images/hero/header-symbol-circle.png") type("image/png"));`}
	aria-labelledby="hero-heading"
>
	<div class="max-w-7xl mx-auto relative z-10">
		<div class="hero-content">
			<div class="hero-copy-block">
				<h1 id="hero-heading" class="hero-title">
					{t('hero.headline', locale, translations)}
				</h1>
				<p class="hero-copy" set:html={t('hero.subtitle', locale, translations)} />
			</div>

			<a class="hero-scroll-cue" href={getLocalizedHashLink('#benefits', locale)} aria-label="Scroll to benefits">
				<span aria-hidden="true">↓</span>
			</a>
		</div>
	</div>
	<div class="hero-art" aria-hidden="true">
		<picture>
			<source srcset={`${base}images/hero/header-people.webp`} type="image/webp" />
			<img
				class="hero-people"
				src={`${base}images/hero/header-people.png`}
				alt=""
				width="1600"
				height="1357"
				loading="eager"
				decoding="async"
			/>
		</picture>
		<div class="hero-symbol-circle"></div>
		<div class="hero-badge">Free<br />to try</div>
	</div>
</section>

<style>
	.hero-section {
		--hero-padding-bottom: clamp(4rem, 6vw, 6rem);
		--hero-bg-split: calc(50% + clamp(9.25rem, 13.8vw, 12.5rem));

		background-image: var(--hero-bg-image),
			linear-gradient(
				90deg,
				#5a5420 0 var(--hero-bg-split),
				transparent var(--hero-bg-split) 100%
			),
			linear-gradient(
				180deg,
				#858414 0%,
				#c5cc02 20%,
				#cdd604 50%,
				#c3cb03 78%,
				#a6a90b 100%
			);
		background-position: top center, top center, top center;
		background-repeat: no-repeat;
		background-size: auto 100%, 100% 100%, 100% 100%;
		color: #fff;
		min-height: clamp(36rem, 53vw, 48rem);
		overflow: hidden;
		padding-bottom: var(--hero-padding-bottom);
		padding-top: clamp(8rem, 11vw, 10rem);
		position: relative;
	}

	.hero-content {
		min-height: clamp(25rem, 37vw, 34rem);
		position: relative;
	}

	.hero-copy-block {
		max-width: min(46vw, 42rem);
		padding-top: clamp(4rem, 10vw, 9.5rem);
		position: relative;
		z-index: 2;
	}

	.hero-title {
		color: #d2d900;
		font-family: var(--font-display);
		font-size: var(--type-section-title);
		font-weight: var(--font-weight-display);
		letter-spacing: 0.01em;
		line-height: 0.82;
		margin: 0 0 1.35rem;
		text-wrap: balance;
	}

	.hero-copy {
		color: rgba(255, 255, 255, 0.82);
		font-family: var(--font-copy);
		font-size: var(--type-body);
		font-weight: var(--font-weight-body);
		line-height: 1.2;
		margin: 0;
		max-width: 36rem;
	}

	.hero-copy :global(strong) {
		color: #fff;
		font-weight: 700;
	}

	.hero-art {
		bottom: 0;
		left: 50%;
		max-width: 80rem;
		pointer-events: none;
		position: absolute;
		top: 0;
		transform: translateX(-50%);
		width: calc(100% - 4rem);
		z-index: 1;
	}

	.hero-people {
		bottom: 0;
		height: auto;
		position: absolute;
		right: 0;
		width: min(50vw, 43rem);
		z-index: 1;
	}

	.hero-symbol-circle {
		background-image: var(--hero-circle-image);
		background-position: center;
		background-repeat: no-repeat;
		background-size: contain;
		height: clamp(9rem, 12vw, 13rem);
		opacity: 0.78;
		position: absolute;
		right: clamp(3.25rem, 5vw, 5rem);
		top: clamp(6.75rem, 19%, 9.5rem);
		width: clamp(9rem, 12vw, 13rem);
		z-index: 2;
	}

	.hero-badge {
		align-items: center;
		background: #0796a7;
		border-radius: 999px;
		box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
		color: #fff;
		display: flex;
		font-family: var(--font-display);
		font-size: clamp(1.3rem, 2.4vw, 2.4rem);
		font-weight: var(--font-weight-display);
		height: clamp(5.5rem, 8vw, 7.5rem);
		justify-content: center;
		line-height: 0.82;
		position: absolute;
		right: clamp(0.75rem, 2vw, 2rem);
		text-align: center;
		text-transform: uppercase;
		top: clamp(13.5rem, 34%, 17rem);
		width: clamp(5.5rem, 8vw, 7.5rem);
		z-index: 3;
	}

	.hero-scroll-cue {
		align-items: center;
		border: 1px solid rgba(255, 255, 255, 0.58);
		border-radius: 999px;
		bottom: calc(var(--hero-padding-bottom) * -0.56);
		color: rgba(255, 255, 255, 0.8);
		display: flex;
		font-family: var(--font-body);
		font-size: 1.35rem;
		height: 3.2rem;
		justify-content: center;
		left: 50%;
		position: absolute;
		text-decoration: none;
		transform: translateX(-50%);
		transition: background-color 0.2s ease, color 0.2s ease;
		width: 2.25rem;
		z-index: 5;
	}

	.hero-scroll-cue:hover {
		background: rgba(255, 255, 255, 0.12);
		color: #fff;
	}

	@media (max-width: 1023px) {
		.hero-section {
			background-position: top center, top center;
			min-height: 46rem;
			padding-top: 7.5rem;
		}

		.hero-people {
			opacity: 0.9;
			right: -7rem;
			width: min(82vw, 38rem);
		}

		.hero-copy-block {
			max-width: 37rem;
			padding-top: 3rem;
		}

		.hero-symbol-circle,
		.hero-badge {
			display: none;
		}
	}

	@media (max-width: 640px) {
		.hero-section {
			--hero-padding-bottom: 3.5rem;

			min-height: 43rem;
			padding-bottom: var(--hero-padding-bottom);
			padding-top: 6.5rem;
		}

		.hero-people {
			opacity: 0.58;
			right: -12rem;
			width: 33rem;
		}

		.hero-copy-block {
			max-width: 100%;
			padding-top: 2.5rem;
		}

		.hero-title {
			max-width: 20rem;
		}

		.hero-copy {
			max-width: 20rem;
		}
	}
</style>
