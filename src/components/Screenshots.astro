---
import { loadTranslations, t } from '../utils/i18n';
import type { Locale } from '../i18n/types';

import phoneSessionPlayerLight from '../assets/images/phone_session_player_light.png';
import phoneSessionPlayerDark from '../assets/images/phone_session_player_dark.png';
import phoneSessionBrowserLight from '../assets/images/phone_session_browser_light.png';
import phoneSessionBrowserDark from '../assets/images/phone_session_browser_dark.png';
import phoneToneEditorLight from '../assets/images/phone_tone_editor_light.png';
import phoneToneEditorDark from '../assets/images/phone_tone_editor_dark.png';
import phoneSimpleSessionEditorLight from '../assets/images/phone_simple_session_editor_light.png';
import phoneSimpleSessionEditorDark from '../assets/images/phone_simple_session_editor_dark.png';
import phoneQrDisplayLight from '../assets/images/phone_qr_display_light.png';
import phoneQrDisplayDark from '../assets/images/phone_qr_display_dark.png';
import phoneAddTrackModalLight from '../assets/images/phone_add_track_modal_light.png';
import phoneAddTrackModalDark from '../assets/images/phone_add_track_modal_dark.png';
import phoneFullSessionEditorLight from '../assets/images/phone_full_session_editor_light.png';
import phoneFullSessionEditorDark from '../assets/images/phone_full_session_editor_dark.png';
import phoneRitualsListLight from '../assets/images/phone_rituals_list_light.png';
import phoneRitualsListDark from '../assets/images/phone_rituals_list_dark.png';
import phoneRitualEditLight from '../assets/images/phone_ritual_edit_light.png';
import phoneRitualEditDark from '../assets/images/phone_ritual_edit_dark.png';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const screenshots = [
	{
		light: phoneSessionPlayerLight,
		dark: phoneSessionPlayerDark,
		caption: t('screenshots.player', locale, translations),
		alt: 'MindState player with lock-screen controls and mix artwork',
	},
	{
		light: phoneSessionBrowserLight,
		dark: phoneSessionBrowserDark,
		caption: t('screenshots.mixes', locale, translations),
		alt: 'Mixes library with included and custom mixes by category',
	},
	{
		light: phoneToneEditorLight,
		dark: phoneToneEditorDark,
		caption: t('screenshots.beatPicker', locale, translations),
		alt: 'Beat picker with brainwave bands and Solfeggio tones',
	},
	{
		light: phoneSimpleSessionEditorLight,
		dark: phoneSimpleSessionEditorDark,
		caption: t('screenshots.quickEditor', locale, translations),
		alt: 'Quick editor with four mix slots',
	},
	{
		light: phoneQrDisplayLight,
		dark: phoneQrDisplayDark,
		caption: t('screenshots.shareQr', locale, translations),
		alt: 'Share screen with branded QR code for mix sharing',
	},
	{
		light: phoneAddTrackModalLight,
		dark: phoneAddTrackModalDark,
		caption: t('screenshots.addTrack', locale, translations),
		alt: 'Full editor add-track sheet with tone, noise, effect, and file types',
	},
	{
		light: phoneFullSessionEditorLight,
		dark: phoneFullSessionEditorDark,
		caption: t('screenshots.fullEditor', locale, translations),
		alt: 'Full editor with volume envelopes and track controls',
	},
	{
		light: phoneRitualsListLight,
		dark: phoneRitualsListDark,
		caption: t('screenshots.ritualsList', locale, translations),
		alt: 'Daily Rituals list with scheduled mixes',
	},
	{
		light: phoneRitualEditLight,
		dark: phoneRitualEditDark,
		caption: t('screenshots.ritualEdit', locale, translations),
		alt: 'Ritual editor with time, repeat days, and linked mix',
	},
];
---

<section id="screenshots" class="section-plain py-24 px-4 sm:px-6 lg:px-8">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-16">
			<h2 class="text-5xl md:text-6xl font-bold mb-4 text-bhutan-primary">
				{t('screenshots.title', locale, translations)}
			</h2>
			<p class="text-xl max-w-3xl mx-auto text-bhutan-secondary">
				{t('screenshots.subtitle', locale, translations)}
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			{screenshots.map((screenshot) => (
				<div class="screenshot-card bg-bhutan-secondary rounded-3xl p-5 shadow-lg transition-all">
					<picture>
						<source srcset={screenshot.dark.src} media="(prefers-color-scheme: dark)" />
						<img
							src={screenshot.light.src}
							alt={screenshot.alt}
							class="rounded-2xl w-full aspect-[1284/2778] object-cover"
							loading="lazy"
						/>
					</picture>
					<p class="text-center mt-4 font-medium text-bhutan-primary">{screenshot.caption}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.screenshot-card {
		border: 1px solid var(--border-light);
		box-shadow: var(--shadow-card);
	}

	.screenshot-card:hover {
		box-shadow: 0 24px 60px rgba(104, 31, 54, 0.2);
		transform: translateY(-6px);
	}
</style>
