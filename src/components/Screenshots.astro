---
import { appScreenshots, featuredScreenshotIds, handPlayerScreenshot } from '../data/appScreenshots';
import { loadTranslations, t, getLocalizedLink } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const featuredScreenshots = featuredScreenshotIds
	.map((id) => appScreenshots.find((screenshot) => screenshot.id === id))
	.filter((screenshot) => screenshot !== undefined);
---

<section id="screenshots" class="screenshots-showcase section-plain" aria-labelledby="screenshots-heading">
	<div class="screenshots-showcase__inner">
		<div class="screenshots-showcase__header">
			<h2 id="screenshots-heading" class="screenshots-showcase__title">
				{t('screenshots.title', locale, translations)}
			</h2>
			<p class="screenshots-showcase__subtitle">
				{t('screenshots.subtitle', locale, translations)}
			</p>
		</div>

		<div class="screenshots-showcase__stage">
			{featuredScreenshots.map((screenshot, index) => (
				<figure class={`screenshots-showcase__phone screenshots-showcase__phone--${index + 1}`}>
					{index === 0 ? (
						<picture>
							<source srcset={handPlayerScreenshot.darkWebp.src} media="(prefers-color-scheme: dark)" type="image/webp" />
							<source srcset={handPlayerScreenshot.dark.src} media="(prefers-color-scheme: dark)" />
							<source srcset={handPlayerScreenshot.lightWebp.src} type="image/webp" />
							<img
								src={handPlayerScreenshot.light.src}
								alt={screenshot.alt}
								width={handPlayerScreenshot.light.width}
								height={handPlayerScreenshot.light.height}
								loading="lazy"
							/>
						</picture>
					) : (
						<picture>
							<source srcset={screenshot.darkWebp.src} media="(prefers-color-scheme: dark)" type="image/webp" />
							<source srcset={screenshot.dark.src} media="(prefers-color-scheme: dark)" />
							<source srcset={screenshot.lightWebp.src} type="image/webp" />
							<img
								src={screenshot.light.src}
								alt={screenshot.alt}
								width={screenshot.light.width}
								height={screenshot.light.height}
								loading="lazy"
							/>
						</picture>
					)}
					<figcaption>{t(screenshot.captionKey, locale, translations)}</figcaption>
				</figure>
			))}
		</div>

		<div class="screenshots-showcase__more">
			<span class="screenshots-showcase__rule" aria-hidden="true"></span>
			<a class="screenshots-showcase__link" href={getLocalizedLink('/screenshots/', locale)}>
				<span>{t('screenshots.seeMore', locale, translations)}</span>
				<svg viewBox="0 0 48 16" aria-hidden="true">
					<path d="M1 8h43m-6-6 6 6-6 6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" />
				</svg>
			</a>
		</div>
	</div>
</section>

<style>
	.screenshots-showcase {
		background: #fffaf7;
		overflow: hidden;
		padding: clamp(4.5rem, 7vw, 6.5rem) 1rem clamp(5rem, 8vw, 7rem);
	}

	.screenshots-showcase__inner {
		margin: 0 auto;
		max-width: 76rem;
	}

	.screenshots-showcase__header {
		margin: 0 auto clamp(2.3rem, 4vw, 3.4rem);
		text-align: center;
	}

	.screenshots-showcase__title {
		color: #70402f;
		font-size: clamp(3.3rem, 2.7rem + 1.4vw, 4.55rem);
		margin: 0 0 0.6rem;
	}

	.screenshots-showcase__subtitle {
		color: rgba(77, 46, 42, 0.68);
		font-family: var(--font-copy);
		font-size: clamp(1.25rem, 1rem + 0.65vw, 1.85rem);
		font-weight: var(--font-weight-body);
		line-height: 1.18;
		margin: 0 auto;
		max-width: 60rem;
	}

	.screenshots-showcase__stage {
		align-items: start;
		display: grid;
		gap: clamp(1.7rem, 4.3vw, 4.9rem);
		grid-template-columns: minmax(17rem, 2.1fr) repeat(3, minmax(9.5rem, 1fr));
	}

	.screenshots-showcase__phone {
		margin: 0;
		position: relative;
	}

	.screenshots-showcase__phone img {
		display: block;
		filter: drop-shadow(0 24px 42px rgba(45, 18, 16, 0.18));
		height: auto;
		width: 100%;
	}

	.screenshots-showcase__phone figcaption {
		border: 0;
		clip: rect(0 0 0 0);
		height: 1px;
		margin: -1px;
		overflow: hidden;
		padding: 0;
		position: absolute;
		white-space: nowrap;
		width: 1px;
	}

	.screenshots-showcase__phone--1 {
		margin-top: -0.4rem;
		width: min(100%, 28rem);
	}

	.screenshots-showcase__phone--1 img {
		filter: none;
	}

	.screenshots-showcase__phone--2,
	.screenshots-showcase__phone--3,
	.screenshots-showcase__phone--4 {
		margin-top: clamp(0.4rem, 1vw, 1rem);
		width: min(100%, 13.2rem);
	}

	.screenshots-showcase__more {
		align-items: center;
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr auto;
		margin-top: clamp(2.6rem, 5vw, 4.4rem);
	}

	.screenshots-showcase__rule {
		background: rgba(77, 46, 42, 0.26);
		height: 1px;
		width: 100%;
	}

	.screenshots-showcase__link {
		align-items: center;
		border: 1px solid rgba(77, 46, 42, 0.32);
		border-radius: 999px;
		color: rgba(77, 46, 42, 0.72);
		display: inline-flex;
		font-family: var(--font-body);
		font-size: clamp(1.05rem, 0.95rem + 0.25vw, 1.25rem);
		font-weight: var(--font-weight-ui);
		gap: 0.65rem;
		line-height: 1;
		padding: 0.55rem 0.75rem 0.55rem 1rem;
		text-decoration: none;
	}

	.screenshots-showcase__link svg {
		height: 0.9rem;
		width: 2.8rem;
	}

	.screenshots-showcase__link:hover {
		background: rgba(244, 95, 17, 0.08);
		border-color: rgba(244, 95, 17, 0.46);
		color: #e66a00;
	}

	@media (prefers-color-scheme: dark) {
		.screenshots-showcase {
			background: #220c12;
		}

		.screenshots-showcase__title {
			color: #fff7f0;
		}

		.screenshots-showcase__subtitle,
		.screenshots-showcase__link {
			color: rgba(255, 232, 217, 0.72);
		}

		.screenshots-showcase__rule {
			background: rgba(255, 232, 217, 0.2);
		}

		.screenshots-showcase__link {
			border-color: rgba(255, 232, 217, 0.28);
		}
	}

	@media (max-width: 900px) {
		.screenshots-showcase__stage {
			gap: 1.25rem;
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.screenshots-showcase__phone--1,
		.screenshots-showcase__phone--2,
		.screenshots-showcase__phone--3,
		.screenshots-showcase__phone--4 {
			justify-self: center;
			margin-top: 0;
			width: min(100%, 13.5rem);
		}

		.screenshots-showcase__phone--1 {
			width: min(100%, 15.8rem);
		}
	}

	@media (max-width: 560px) {
		.screenshots-showcase {
			padding-inline: 1.25rem;
		}

		.screenshots-showcase__stage {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.screenshots-showcase__more {
			align-items: stretch;
			grid-template-columns: 1fr;
		}
	}
</style>
