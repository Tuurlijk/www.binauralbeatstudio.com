---
import { loadTranslations, t } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const quoteColumns = [
	[1, 10],
	[4, 3],
	[6, 7],
] as const;
---

<section id="quotes" class="quotes-section section-plain px-4 sm:px-6 lg:px-8" aria-labelledby="quotes-heading">
	<div class="quotes-inner max-w-7xl mx-auto">
		<div class="quotes-header">
			<h2 id="quotes-heading" class="quotes-title">
				{t('quotes.title', locale, translations)}
			</h2>
			<p class="quotes-subtitle">
				{t('quotes.subtitle', locale, translations)}
			</p>
		</div>

		<div class="quotes-columns">
			{quoteColumns.map((column) => (
				<div class="quotes-column">
					{column.map((n) => (
						<blockquote class="quote-item">
							<p class="quote-item__text">
								"{t(`quotes.quote${n}.text`, locale, translations)}"
							</p>
							<cite class="quote-item__source">
								{t(`quotes.quote${n}.source`, locale, translations)}
							</cite>
						</blockquote>
					))}
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.quotes-section {
		padding-bottom: clamp(4rem, 7vw, 6rem);
		padding-top: clamp(4rem, 7vw, 6rem);
	}

	.quotes-inner {
		max-width: 72rem;
	}

	.quotes-header {
		margin: 0 auto clamp(1.75rem, 3vw, 2.5rem);
		text-align: center;
	}

	.quotes-title {
		color: #5e4f46;
		font-family: var(--font-display);
		font-size: var(--type-section-title);
		font-weight: var(--font-weight-display);
		letter-spacing: 0.01em;
		line-height: 0.86;
		margin: 0 0 0.65rem;
	}

	.quotes-subtitle {
		color: rgba(94, 79, 70, 0.72);
		font-family: var(--font-copy);
		font-size: var(--type-body);
		font-weight: var(--font-weight-body);
		line-height: 1.2;
		margin: 0;
	}

	.quotes-columns {
		display: grid;
		gap: clamp(1.75rem, 3.5vw, 3.25rem);
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.quotes-column {
		display: grid;
		gap: clamp(1.5rem, 3vw, 2.35rem);
		align-content: start;
	}

	.quote-item {
		margin: 0;
	}

	.quote-item__text {
		color: #5e4f46;
		font-family: var(--font-body);
		font-size: clamp(1.2rem, 1rem + 0.45vw, 1.55rem);
		font-weight: var(--font-weight-card-title);
		letter-spacing: 0;
		line-height: 1.02;
		margin: 0 0 0.45rem;
	}

	.quote-item__source {
		color: rgba(94, 79, 70, 0.68);
		display: block;
		font-family: var(--font-copy);
		font-size: var(--type-body);
		font-style: normal;
		font-weight: var(--font-weight-body);
		line-height: 1.15;
	}

	@media (max-width: 1023px) {
		.quotes-columns {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 767px) {
		.quotes-header {
			text-align: left;
		}

		.quotes-columns {
			grid-template-columns: 1fr;
		}
	}
</style>
