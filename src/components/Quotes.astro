---
import { loadTranslations, t } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const quoteOrder = [9, 10, 1, 2, 3, 4, 5, 6, 7, 8] as const;
---

<section id="quotes" class="section-gradient py-20 px-4 sm:px-6 lg:px-8" aria-labelledby="quotes-heading">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-16">
			<h2 id="quotes-heading" class="text-4xl md:text-5xl font-bold mb-4 text-bhutan-primary">
				{t('quotes.title', locale, translations)}
			</h2>
			<p class="text-xl max-w-3xl mx-auto text-bhutan-secondary">
				{t('quotes.subtitle', locale, translations)}
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 quotes-grid">
			{quoteOrder.map((n) => (
				<blockquote
					class={`quote-card quote-${n} p-8 rounded-2xl border`}
					style="background-color: var(--bg-secondary); border-color: var(--border-light);"
				>
					<div class="mb-4" aria-hidden="true">
						<svg class="w-8 h-8 text-bhutan-accent opacity-50" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.996 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.984zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
						</svg>
					</div>
					<p class="text-lg md:text-xl italic mb-4 leading-relaxed text-bhutan-primary">
						"{t(`quotes.quote${n}.text`, locale, translations)}"
					</p>
					<cite class="text-sm text-bhutan-secondary not-italic">
						— {t(`quotes.quote${n}.source`, locale, translations)}
					</cite>
				</blockquote>
			))}
		</div>
	</div>
</section>

<style>
	.quotes-grid {
		position: relative;
	}

	.quote-card {
		transform-origin: center;
		transition: transform 0.3s ease, box-shadow 0.3s ease, z-index 0s;
		position: relative;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
	}

	.quote-1 { transform: rotate(-2deg); }
	.quote-2 { transform: rotate(1.5deg); }
	.quote-3 { transform: rotate(-1deg); }
	.quote-4 { transform: rotate(2deg); }
	.quote-5 { transform: rotate(-1.5deg); }
	.quote-6 { transform: rotate(0.5deg); }
	.quote-7 { transform: rotate(-0.5deg); }
	.quote-8 { transform: rotate(1deg); }
	.quote-9 { transform: rotate(-1.2deg); }
	.quote-10 { transform: rotate(0.8deg); }

	.quote-card:hover {
		transform: rotate(0deg) scale(1.03);
		z-index: 10;
		box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
		transition: transform 0.3s ease, box-shadow 0.3s ease, z-index 0s 0.3s;
	}

	@media (max-width: 767px) {
		.quote-card {
			transform: rotate(0deg) !important;
		}

		.quote-card:hover {
			transform: scale(1.02) !important;
		}
	}
</style>
