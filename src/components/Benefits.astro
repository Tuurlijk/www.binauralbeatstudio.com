---
import { benefitCards } from '../data/benefits';
import { loadTranslations, t, getLocalizedLink } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);
const base = import.meta.env.BASE_URL;

const subtitle = translations.aboutBinauralBeats?.benefits?.subtitle ?? '';
const showSubtitle = subtitle.trim().length > 0;
const benefitsPath = getLocalizedLink('/benefits/', locale);
---

<section id="benefits" class="section-plain py-24 px-4 sm:px-6 lg:px-8" aria-labelledby="benefits-heading">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-12 md:mb-16">
			<h2 id="benefits-heading" class="benefits-heading text-bhutan-primary max-w-4xl mx-auto">
				{t('aboutBinauralBeats.benefits.title', locale, translations)}
			</h2>
			{showSubtitle && (
				<p class="text-lg md:text-xl max-w-3xl mx-auto mt-5 text-bhutan-secondary">
					{subtitle}
				</p>
			)}
		</div>

		<div class="benefits-grid">
			{benefitCards.map((benefit) => (
				<a
					class="benefit-card"
					href={`${benefitsPath}#${benefit.slug}`}
					style={`--benefit-panel: ${benefit.panel}; --benefit-title: ${benefit.title};`}
				>
					<div class="benefit-card__media">
						<picture class="benefit-card__picture">
							<source
								srcset={`${base}images/benefits/${benefit.visual.replace('.png', '.webp')}`}
								type="image/webp"
							/>
							<img
								class="benefit-card__visual"
								src={`${base}images/benefits/${benefit.visual}`}
								alt=""
								width="640"
								height="640"
								loading="lazy"
							/>
						</picture>
						<h3 class="benefit-card__title">
							{t(`aboutBinauralBeats.benefits.${benefit.id}.title`, locale, translations)}
						</h3>
					</div>

					<div class="benefit-card__body">
						<picture>
							<source
								srcset={`${base}images/benefits/${benefit.symbol.replace('.png', '.webp')}`}
								type="image/webp"
							/>
							<img
								class="benefit-card__symbol"
								src={`${base}images/benefits/${benefit.symbol}`}
								alt=""
								width="42"
								height="42"
								loading="lazy"
								aria-hidden="true"
							/>
						</picture>

						<p class="benefit-card__copy">
							{t(`aboutBinauralBeats.benefits.${benefit.id}.description`, locale, translations)}
						</p>

						<span
							class="benefit-card__explore"
						>
							<span>{t('aboutBinauralBeats.benefits.explore', locale, translations)}</span>
							<span class="benefit-card__arrow" aria-hidden="true">→</span>
						</span>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.benefits-heading {
		font-size: clamp(2.6rem, 2rem + 2vw, 4.5rem);
		line-height: 0.92;
	}

	.benefits-grid {
		display: grid;
		gap: clamp(0.75rem, 1.3vw, 1rem);
		grid-template-columns: repeat(1, minmax(0, 1fr));
	}

	.benefit-card {
		background: var(--benefit-panel);
		color: #fff;
		display: flex;
		flex-direction: column;
		min-height: clamp(38rem, 53vw, 46rem);
		overflow: hidden;
		text-decoration: none;
		transition: transform 0.25s ease;
	}

	.benefit-card:hover {
		transform: translateY(-6px);
	}

	.benefit-card__media {
		flex: 0 0 56%;
		overflow: hidden;
		position: relative;
	}

	.benefit-card__picture {
		display: block;
		height: 100%;
	}

	.benefit-card__visual {
		display: block;
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.benefit-card__body {
		background: var(--benefit-panel);
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: clamp(1.35rem, 2vw, 1.75rem);
	}

	.benefit-card__title {
		color: var(--benefit-title);
		font-family: var(--font-display);
		font-size: clamp(2.05rem, 1.45rem + 1.25vw, 3.05rem);
		font-weight: var(--font-weight-display);
		left: clamp(1.35rem, 2.5vw, 2.35rem);
		line-height: 0.82;
		margin: 0;
		max-width: 86%;
		position: absolute;
		text-shadow: 0 2px 12px rgba(33, 22, 20, 0.18);
		text-wrap: balance;
		top: clamp(1.7rem, 3.5vw, 2.75rem);
	}

	.benefit-card__symbol {
		height: 2.75rem;
		margin: 0 auto 1.35rem;
		object-fit: contain;
		opacity: 0.92;
		width: 2.75rem;
	}

	.benefit-card__explore {
		align-items: center;
		align-self: flex-end;
		border: 1px solid rgba(255, 255, 255, 0.82);
		border-radius: 999px;
		color: rgba(255, 255, 255, 0.92);
		display: inline-flex;
		font-family: var(--font-body);
		font-size: clamp(1rem, 0.9rem + 0.25vw, 1.2rem);
		gap: 1.1rem;
		justify-content: space-between;
		line-height: 1;
		margin-top: auto;
		min-width: 8.2rem;
		padding: 0.48rem 0.5rem 0.48rem 1.25rem;
		text-decoration: none;
		transition: background-color 0.2s ease;
	}

	.benefit-card__explore:hover {
		background: rgba(255, 255, 255, 0.14);
	}

	.benefit-card__arrow {
		align-items: center;
		border-left: 1px solid rgba(255, 255, 255, 0.72);
		display: inline-flex;
		height: 1.1rem;
		justify-content: flex-end;
		min-width: 2.2rem;
	}

	.benefit-card__copy {
		font-family: var(--font-copy);
		font-size: var(--type-body);
		font-weight: 300;
		hyphens: auto;
		line-height: 1.18;
		margin: 0 0 1.35rem;
		max-width: 100%;
		overflow-wrap: normal;
	}

	@media (min-width: 768px) {
		.benefits-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1280px) {
		.benefits-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.benefit-card {
			min-height: 46rem;
		}
	}
</style>
