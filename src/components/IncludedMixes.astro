---
import { loadTranslations, t } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const categories = [1, 2, 3, 4, 5, 6, 7, 8] as const;
---

<section id="included-mixes" class="section-plain py-20 px-4 sm:px-6 lg:px-8">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-12">
			<h2 class="text-4xl md:text-5xl font-bold mb-4 text-bhutan-primary">
				{t('includedMixes.title', locale, translations)}
			</h2>
			<p class="text-xl max-w-3xl mx-auto text-bhutan-secondary">
				{t('includedMixes.subtitle', locale, translations)}
			</p>
		</div>

		<div class="flex flex-wrap justify-center gap-3 mb-8">
			{categories.map((n) => (
				<span class="px-4 py-2 rounded-full text-sm font-medium border bg-bhutan-secondary text-bhutan-primary" style="border-color: var(--border-light);">
					{t(`includedMixes.category${n}`, locale, translations)}
				</span>
			))}
		</div>

		<p class="text-center max-w-3xl mx-auto leading-relaxed text-bhutan-secondary">
			{t('includedMixes.note', locale, translations)}
		</p>
	</div>
</section>
