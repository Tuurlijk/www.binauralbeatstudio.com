---
import { loadTranslations, t } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const showIosBuild = false;
const bullets = showIosBuild ? ([1, 2, 3, 4] as const) : ([1, 2, 3] as const);
---

<section id="rituals" class="section-gradient py-20 px-4 sm:px-6 lg:px-8">
	<div class="max-w-4xl mx-auto">
		<div class="text-center mb-10">
			<h2 class="text-4xl md:text-5xl font-bold mb-4 text-bhutan-primary">
				{t('rituals.title', locale, translations)}
			</h2>
			<p class="text-xl leading-relaxed text-bhutan-secondary">
				{t('rituals.subtitle', locale, translations)}
			</p>
		</div>

		<ul class="space-y-4">
			{bullets.map((n) => {
				const key = `rituals.bullet${n}`;
				const value = t(key, locale, translations);
				if (!value || value === key) return null;
				return (
					<li class="flex gap-3 p-4 rounded-xl border bg-bhutan-secondary text-bhutan-secondary" style="border-color: var(--border-light);">
						<span class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold" style="background-color: var(--primary);">
							{n}
						</span>
						<span class="leading-relaxed pt-1">{value}</span>
					</li>
				);
			})}
		</ul>
	</div>
</section>
