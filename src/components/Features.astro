---
import { loadTranslations, t } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const features = [
	{ id: 'feature1', accent: '#6b2438', copy: '#8a4a5c' },
	{ id: 'feature2', accent: '#b8893d', copy: '#9a7348' },
	{ id: 'feature3', accent: '#c73d7a', copy: '#a84f73' },
	{ id: 'feature4', accent: '#d4a82f', copy: '#a8842f' },
	{ id: 'feature5', accent: '#7a4d7f', copy: '#6a4a6e' },
	{ id: 'feature6', accent: '#6b5a4f', copy: '#6e5f57' },
] as const;
---

<section id="features" class="section-gradient py-24 px-4 sm:px-6 lg:px-8" aria-labelledby="features-heading">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-16">
			<h2 id="features-heading" class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-[0.95] text-bhutan-primary">
				{t('features.titlePrefix', locale, translations)}
				<span style="color: var(--primary);">{t('features.titleHighlight', locale, translations)}</span>
				<br />
				{t('features.titleSuffix', locale, translations)}
			</h2>
			<p class="max-w-4xl mx-auto mb-10 leading-relaxed text-bhutan-secondary">
				{t('features.pitch', locale, translations)}
			</p>
			<p class="text-4xl md:text-5xl font-bold mb-4 text-bhutan-primary">
				{t('features.title', locale, translations)}
			</p>
			<p class="text-xl max-w-3xl mx-auto text-bhutan-secondary">
				{t('features.subtitle', locale, translations)}
			</p>
		</div>

		<div class="features-grid">
			{features.map((feature) => (
				<article
					class="feature-card"
					style={`--feature-accent: ${feature.accent}; --feature-copy: ${feature.copy};`}
				>
					<h3 class="feature-card__title">
						{t(`features.${feature.id}.title`, locale, translations)}
					</h3>
					<p class="feature-card__copy">
						{t(`features.${feature.id}.description`, locale, translations)}
					</p>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.features-grid {
		display: grid;
		gap: clamp(1rem, 2vw, 1.5rem);
		grid-template-columns: repeat(1, minmax(0, 1fr));
	}

	.feature-card {
		background: rgba(255, 252, 248, 0.92);
		border: 1px solid var(--feature-accent);
		border-radius: 1.75rem;
		padding: clamp(1.75rem, 2.5vw, 2.35rem);
		text-align: left;
	}

	.feature-card__title {
		color: var(--feature-accent);
		font-family: var(--font-display);
		font-size: clamp(2rem, 1.55rem + 1.1vw, 2.85rem);
		font-weight: var(--font-weight-display);
		letter-spacing: 0.01em;
		line-height: 0.92;
		margin: 0 0 1.15rem;
		text-wrap: balance;
	}

	.feature-card__copy {
		color: var(--feature-copy);
		font-family: var(--font-copy);
		font-size: var(--type-body);
		font-weight: var(--font-weight-body);
		line-height: 1.28;
		margin: 0;
	}

	@media (min-width: 768px) {
		.features-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1024px) {
		.features-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (prefers-color-scheme: dark) {
		.feature-card {
			background: rgba(40, 18, 24, 0.72);
		}
	}
</style>
