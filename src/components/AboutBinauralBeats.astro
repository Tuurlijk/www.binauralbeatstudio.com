---
import { loadTranslations, t } from '../utils/i18n';
import type { Locale } from '../i18n/types';

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const frequencyKeys = [
	'frequencyDelta',
	'frequencyTheta',
	'frequencyAlpha',
	'frequencyBeta',
	'frequencyGamma',
] as const;
---

<section id="about-binaural-beats" class="section-plain py-20 px-4 sm:px-6 lg:px-8" aria-labelledby="about-binaural-beats-heading">
	<div class="max-w-7xl mx-auto">
		<div class="brainwave-explainer mb-20">
			<div class="brainwave-explainer__header">
				<h2 id="about-binaural-beats-heading" class="brainwave-explainer__title">
					{t('aboutBinauralBeats.howItWorks.title', locale, translations)}
				</h2>
				<p class="brainwave-explainer__subtitle">
					{t('aboutBinauralBeats.howItWorks.subtitle', locale, translations)}
				</p>
			</div>

			<div class="brainwave-explainer__body">
				<div class="brainwave-explainer__column">
					<p class="brainwave-explainer__intro">
						{t('aboutBinauralBeats.howItWorks.explanation', locale, translations)}
					</p>
					<p>
						{t('aboutBinauralBeats.howItWorks.noHeadphones', locale, translations)}
					</p>
				</div>
				<div class="brainwave-explainer__column">
					<div>
						<p>
							{t('aboutBinauralBeats.howItWorks.frequencyIntro', locale, translations)}
						</p>
						<ul class="brainwave-explainer__list">
							{frequencyKeys.map((key) => (
								<li>{t(`aboutBinauralBeats.howItWorks.${key}`, locale, translations)}</li>
							))}
						</ul>
					</div>
					<p>
						{t('aboutBinauralBeats.howItWorks.personalization', locale, translations)}
					</p>
				</div>
			</div>
		</div>

		<!-- AD/HD Research Sections -->
		<div class="mb-12 grid grid-cols-1 md:grid-cols-2 gap-8">
			<!-- AD/HD Noise -->
			<div class="bg-bhutan-secondary p-8 rounded-2xl border" style="border-color: var(--border-light);">
				<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4" style="background-color: var(--primary);">
					<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
					</svg>
				</div>
				<h3 class="text-2xl font-bold mb-3 text-bhutan-primary">
					{t('aboutBinauralBeats.adhdNoise.title', locale, translations)}
				</h3>
				<p class="text-lg font-semibold mb-4 text-bhutan-secondary">
					{t('aboutBinauralBeats.adhdNoise.subtitle', locale, translations)}
				</p>
				<p class="leading-relaxed text-bhutan-secondary">
					{t('aboutBinauralBeats.adhdNoise.description', locale, translations)}
				</p>
			</div>

			<!-- AD/HD Binaural -->
			<div class="bg-bhutan-secondary p-8 rounded-2xl border" style="border-color: var(--border-light);">
				<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4" style="background-color: var(--secondary);">
					<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
					</svg>
				</div>
				<h3 class="text-2xl font-bold mb-3 text-bhutan-primary">
					{t('aboutBinauralBeats.adhdBinaural.title', locale, translations)}
				</h3>
				<p class="text-lg font-semibold mb-4 text-bhutan-secondary">
					{t('aboutBinauralBeats.adhdBinaural.subtitle', locale, translations)}
				</p>
				<p class="leading-relaxed text-bhutan-secondary">
					{t('aboutBinauralBeats.adhdBinaural.description', locale, translations)}
				</p>
			</div>
		</div>

		<!-- Safety & Research Section -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<!-- Safety -->
			<div class="bg-bhutan-secondary p-8 rounded-2xl border" style="border-color: var(--border-light);">
				<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4" style="background-color: var(--accent);">
					<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
					</svg>
				</div>
				<h3 class="text-2xl font-bold mb-3 text-bhutan-primary">
					{t('aboutBinauralBeats.safety.title', locale, translations)}
				</h3>
				<p class="text-lg font-semibold mb-4 text-bhutan-secondary">
					{t('aboutBinauralBeats.safety.subtitle', locale, translations)}
				</p>
				<p class="leading-relaxed text-bhutan-secondary mb-4">
					{t('aboutBinauralBeats.safety.general', locale, translations)}
				</p>
				<p class="leading-relaxed text-bhutan-secondary text-sm">
					{t('aboutBinauralBeats.safety.precautions', locale, translations)}
				</p>
			</div>

			<!-- Research -->
			<div class="bg-bhutan-secondary p-8 rounded-2xl border" style="border-color: var(--border-light);">
				<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4" style="background-color: var(--tertiary);">
					<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
					</svg>
				</div>
				<h3 class="text-2xl font-bold mb-3 text-bhutan-primary">
					{t('aboutBinauralBeats.research.title', locale, translations)}
				</h3>
				<p class="text-lg font-semibold mb-4 text-bhutan-secondary">
					{t('aboutBinauralBeats.research.subtitle', locale, translations)}
				</p>
				<p class="leading-relaxed text-bhutan-secondary">
					{t('aboutBinauralBeats.research.findings', locale, translations)}
				</p>
			</div>
		</div>

	</div>
</section>

<style>
	.brainwave-explainer {
		background:
			radial-gradient(ellipse 42% 38% at 17% 92%, rgba(255, 255, 255, 0.12), transparent 72%),
			radial-gradient(ellipse 32% 40% at 78% 34%, rgba(255, 255, 255, 0.18), transparent 72%),
			radial-gradient(ellipse 34% 46% at 100% 20%, rgba(255, 255, 255, 0.14), transparent 72%),
			linear-gradient(135deg, #e8894f 0%, #ee7300 55%, #e76300 100%);
		color: #fff;
		overflow: hidden;
		padding: clamp(3.5rem, 6vw, 5rem) clamp(1.75rem, 5vw, 4rem);
		position: relative;
	}

	.brainwave-explainer::before,
	.brainwave-explainer::after {
		background: rgba(255, 255, 255, 0.12);
		content: "";
		pointer-events: none;
		position: absolute;
	}

	.brainwave-explainer::before {
		border-radius: 50% 0 50% 50%;
		height: 18rem;
		left: -4rem;
		top: -3rem;
		transform: rotate(8deg);
		width: 28rem;
	}

	.brainwave-explainer::after {
		border-radius: 50%;
		bottom: -10rem;
		height: 24rem;
		right: -7rem;
		width: 30rem;
	}

	.brainwave-explainer__header,
	.brainwave-explainer__body {
		position: relative;
		z-index: 1;
	}

	.brainwave-explainer__header {
		margin: 0 auto clamp(2rem, 4vw, 3rem);
		text-align: center;
	}

	.brainwave-explainer__title {
		color: #fff;
		font-family: var(--font-display);
		font-size: var(--type-section-title);
		font-weight: var(--font-weight-display);
		letter-spacing: 0.01em;
		line-height: 0.86;
		margin: 0 0 0.65rem;
	}

	.brainwave-explainer__subtitle {
		color: rgba(255, 255, 255, 0.86);
		font-family: var(--font-body);
		font-size: clamp(1.35rem, 1.1rem + 0.75vw, 1.9rem);
		font-weight: var(--font-weight-ui);
		line-height: 1;
		margin: 0;
	}

	.brainwave-explainer__body {
		display: grid;
		gap: clamp(2rem, 5vw, 5rem);
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.brainwave-explainer__column {
		display: grid;
		gap: 1.35rem;
		align-content: start;
	}

	.brainwave-explainer__column p {
		color: rgba(255, 255, 255, 0.88);
		font-family: var(--font-copy);
		font-size: var(--type-body);
		font-weight: var(--font-weight-body);
		line-height: 1.32;
		margin: 0;
	}

	.brainwave-explainer__intro {
		font-weight: 700;
	}

	.brainwave-explainer__list {
		color: rgba(255, 255, 255, 0.88);
		font-family: var(--font-copy);
		font-size: var(--type-body);
		font-weight: var(--font-weight-body);
		line-height: 1.32;
		margin: 0.25rem 0 0;
		padding-left: 0;
	}

	.brainwave-explainer__list li {
		display: flex;
		gap: 0.45rem;
		margin: 0;
	}

	.brainwave-explainer__list li::before {
		content: "•";
		flex: 0 0 auto;
	}

	@media (max-width: 767px) {
		.brainwave-explainer {
			padding-inline: 1.5rem;
		}

		.brainwave-explainer__header {
			text-align: left;
		}

		.brainwave-explainer__body {
			grid-template-columns: 1fr;
		}
	}
</style>
