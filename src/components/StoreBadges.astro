---
import { loadTranslations, t } from '../utils/i18n';
import type { Locale } from '../i18n/types';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);

const playStoreUrl = 'https://play.google.com/store/apps/details?id=com.michielroos.mindstate';
---

<div class={`flex flex-col sm:flex-row gap-4 justify-center items-center ${className}`}>
	<a
		href={playStoreUrl}
		target="_blank"
		rel="noopener noreferrer"
		class="bg-white px-8 py-4 rounded-lg text-lg font-semibold transition-all transform hover:scale-105 shadow-lg hover:shadow-xl flex items-center gap-3"
		style="color: var(--primary);"
	>
		<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
			<path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.5,12.92 20.16,13.19L6.05,21.34L14.54,12.85L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z" />
		</svg>
		{t('store.playStore', locale, translations)}
	</a>
</div>
