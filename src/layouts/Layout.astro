---
import '../styles/global.css';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { loadTranslations, t, getLocalizedHashLink, getPagePathFromUrl } from '../utils/i18n';
import type { Locale } from '../i18n/types';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import NavMoreMenu from '../components/NavMoreMenu.astro';
import { buildDefaultStructuredData } from '../lib/structured-data';
import { getOgLocale } from '../lib/seo';

interface Props {
	title?: string;
	description?: string;
	ogType?: 'website' | 'article';
	structuredData?: Record<string, unknown>;
	socialImageUrl?: string;
	socialImageAlt?: string;
}

const locale = Astro.currentLocale as Locale;
const translations = await loadTranslations(locale);
const base = import.meta.env.BASE_URL;

const title = Astro.props.title || t('meta.title', locale, translations);
const description = Astro.props.description || t('meta.description', locale, translations);
const ogType = Astro.props.ogType ?? 'website';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const siteUrl = new URL('/', Astro.site).toString();
const socialImageUrl =
	Astro.props.socialImageUrl ?? new URL('/images/social-card.png', Astro.site).toString();
const socialImageAlt =
	Astro.props.socialImageAlt ??
	'MindState, an app for building and listening to binaural beat mixes on Google Play';
const ogLocale = getOgLocale(locale);
const structuredData =
	Astro.props.structuredData ??
	buildDefaultStructuredData({
		siteUrl,
		description,
		socialImageUrl,
		inLanguage: ogLocale.replace('_', '-'),
	});

const locales: Locale[] = ['en', 'ar', 'es', 'hi', 'id', 'ja', 'nl', 'pt', 'ru', 'zh'];
const pagePath = getPagePathFromUrl(Astro.url.pathname);
const isHomePage = pagePath === '';
const isRTL = locale === 'ar';
---

<!doctype html>
<html lang={locale} dir={isRTL ? 'rtl' : 'ltr'}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="shortcut icon" type="image/x-icon" href={`${base}favicon.ico`} />
		<link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
		<link rel="icon" type="image/png" href={`${base}favicon.png`} />
		<link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16x16.png`} />
		<link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`} />
		<link rel="icon" type="image/png" sizes="48x48" href={`${base}favicon-48x48.png`} />
		<link rel="icon" type="image/png" sizes="64x64" href={`${base}favicon-64x64.png`} />
		<link rel="icon" type="image/png" sizes="96x96" href={`${base}favicon-96x96.png`} />
		<link rel="icon" type="image/png" sizes="128x128" href={`${base}favicon-128x128.png`} />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`} />
		<link rel="apple-touch-icon" sizes="152x152" href={`${base}apple-touch-icon-152x152.png`} />
		<link rel="apple-touch-icon" sizes="167x167" href={`${base}apple-touch-icon-167x167.png`} />
		<link rel="manifest" href={`${base}site.webmanifest`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#f45f11" />
		<link rel="canonical" href={canonicalUrl} />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content="MindStateLab BV" />
		
		<!-- hreflang tags for SEO -->
		{locales.map((loc) => (
			<link
				rel="alternate"
				hreflang={loc}
				href={getAbsoluteLocaleUrl(loc, pagePath)}
			/>
		))}
		<link rel="alternate" hreflang="x-default" href={getAbsoluteLocaleUrl('en', pagePath)} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:url" content={socialImageUrl} />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={socialImageAlt} />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:site_name" content="MindState" />
		{locales.filter((loc) => loc !== locale).map((loc) => (
			<meta property="og:locale:alternate" content={getOgLocale(loc)} />
		))}
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<meta name="twitter:image:alt" content={socialImageAlt} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<style>
			/* CSS-only mobile menu toggle */
			#mobile-menu-toggle:checked ~ #mobile-menu-wrapper #mobile-menu {
				display: block !important;
			}
			#mobile-menu-toggle:not(:checked) ~ #mobile-menu-wrapper #mobile-menu {
				display: none;
			}
		</style>
		
		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-1014717351">
		</script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'AW-1014717351');
		</script>
	</head>
	<body class={`antialiased bg-bhutan-primary text-bhutan-primary ${isRTL ? 'rtl' : 'ltr'} ${isHomePage ? 'layout--home-hero' : ''}`}>
		<nav class={`site-nav fixed top-0 left-0 right-0 z-50 site-nav--hero ${!isHomePage ? 'site-nav--solid' : ''}`} aria-label="Main navigation">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="nav-shell mt-4 flex justify-between items-center min-h-16 px-4 sm:px-5">
					<div class="flex items-center">
						<a href={base} class="site-logo-link flex items-center gap-3 transition-opacity hover:opacity-80">
							<picture>
								<source srcset={`${base}images/hero/logo-mono.webp`} type="image/webp" />
								<img
									src={`${base}images/hero/logo-mono.png`}
									alt=""
									class="site-logo-mark"
								/>
							</picture>
							<span class="site-logo-wordmark">
								<span class="site-logo-name">MindState</span>
								<span class="site-logo-divider" aria-hidden="true">|</span>
								<span class="site-logo-product">Binaural Beat Studio App</span>
							</span>
						</a>
					</div>
					<div class="nav-links hidden lg:flex items-center gap-5">
						<a href={getLocalizedHashLink('#benefits', locale)} class="nav-link transition-colors">{t('nav.benefits', locale, translations)}</a>
						<a href={getLocalizedHashLink('#features', locale)} class="nav-link transition-colors">{t('nav.features', locale, translations)}</a>
						<a href={getLocalizedHashLink('#how-it-works', locale)} class="nav-link transition-colors">{t('nav.howItWorks', locale, translations)}</a>
						<a href={getLocalizedHashLink('#screenshots', locale)} class="nav-link transition-colors">{t('nav.appExamples', locale, translations)}</a>
						<NavMoreMenu variant="hero" />
						<a href={getLocalizedHashLink('#download', locale)} class="nav-download px-5 py-2.5 rounded-full transition-colors text-white bg-bhutan-accent hover:opacity-90">
							{t('nav.downloadApp', locale, translations)}
						</a>
						<LanguageSwitcher variant="hero" />
					</div>
					<label for="mobile-menu-toggle" class="nav-menu-toggle nav-menu-toggle--hero lg:hidden p-2 cursor-pointer" aria-label="Toggle menu">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</label>
					<input type="checkbox" id="mobile-menu-toggle" class="hidden" />
				</div>
			</div>
			<div id="mobile-menu-wrapper" style="overflow: visible;">
				<div class="lg:hidden hidden bg-bhutan-primary border border-bhutan-light rounded-3xl mt-2 shadow-xl" id="mobile-menu" style="overflow: visible;">
				<div class="px-4 pt-2 pb-4 space-y-2" style="overflow: visible;">
					<a href={getLocalizedHashLink('#benefits', locale)} class="block py-2 transition-colors text-bhutan-secondary hover:text-bhutan-accent">{t('nav.benefits', locale, translations)}</a>
					<a href={getLocalizedHashLink('#features', locale)} class="block py-2 transition-colors text-bhutan-secondary hover:text-bhutan-accent">{t('nav.features', locale, translations)}</a>
					<a href={getLocalizedHashLink('#how-it-works', locale)} class="block py-2 transition-colors text-bhutan-secondary hover:text-bhutan-accent">{t('nav.howItWorks', locale, translations)}</a>
					<a href={getLocalizedHashLink('#screenshots', locale)} class="block py-2 transition-colors text-bhutan-secondary hover:text-bhutan-accent">{t('nav.appExamples', locale, translations)}</a>
					<a href={getLocalizedHashLink('#research-studies', locale)} class="block py-2 transition-colors text-bhutan-secondary hover:text-bhutan-accent">{t('nav.research', locale, translations)}</a>
					<a href={getLocalizedHashLink('#faq', locale)} class="block py-2 transition-colors text-bhutan-secondary hover:text-bhutan-accent">{t('nav.faq', locale, translations)}</a>
					<a href={getLocalizedHashLink('#about-binaural-beats', locale)} class="block py-2 transition-colors text-bhutan-secondary hover:text-bhutan-accent">{t('nav.about', locale, translations)}</a>
					<a href={getLocalizedHashLink('#download', locale)} class="block py-2 text-white px-4 rounded-full text-center transition-colors bg-bhutan-accent hover:opacity-90">{isHomePage ? t('nav.downloadApp', locale, translations) : t('nav.download', locale, translations)}</a>
					<div class="pt-4 border-t border-bhutan-light">
						<LanguageSwitcher />
					</div>
				</div>
			</div>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<footer class="site-footer mt-20 text-white">
			<div class="site-footer-wave" aria-hidden="true"></div>
			<div class="site-footer-badge" aria-hidden="true">Free<br />to try</div>
			<div class="site-footer-inner max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="site-footer-grid">
					<div class="site-footer-brand">
						<a href={base} class="site-footer-logo" aria-label="MindState home">
							<picture>
								<source srcset={`${base}images/hero/logo-mono.webp`} type="image/webp" />
								<img
									src={`${base}images/hero/logo-mono.png`}
									alt=""
									class="site-footer-logo-icon"
								/>
							</picture>
							<span class="site-footer-wordmark">
								<span class="site-footer-logo-title">MindState</span>
								<span class="site-footer-logo-divider" aria-hidden="true">|</span>
								<span class="site-footer-logo-subtitle">Binaural Beat Studio App</span>
							</span>
						</a>
						<p>{t('footer.description', locale, translations)}</p>
					</div>

					<div>
						<h4>{t('footer.links', locale, translations)}</h4>
						<ul>
							<li><a href={getLocalizedHashLink('#benefits', locale)}>{t('nav.benefits', locale, translations)}</a></li>
							<li><a href={getLocalizedHashLink('#features', locale)}>{t('nav.features', locale, translations)}</a></li>
							<li><a href={getLocalizedHashLink('#how-it-works', locale)}>{t('nav.howItWorks', locale, translations)}</a></li>
							<li><a href={getLocalizedHashLink('#screenshots', locale)}>{t('nav.screenshots', locale, translations)}</a></li>
							<li><a href={getLocalizedHashLink('#about-binaural-beats', locale)}>{t('nav.about', locale, translations)}</a></li>
							<li><a href={getLocalizedHashLink('#download', locale)}>{t('nav.download', locale, translations)}</a></li>
							<li><a href={`${base}privacy/`}>Privacy Policy</a></li>
							<li><a href={`${base}terms/`}>Terms of Use</a></li>
						</ul>
					</div>

					<div class="site-footer-connect">
						<div class="site-footer-download">
							<h4>{t('footer.download', locale, translations)}</h4>
							<p>{t('footer.downloadDescription', locale, translations)}</p>
							<p><a href={`${base}terms/`}>General Terms and Conditions</a></p>
						</div>

						<div>
							<h4>Connect & follow</h4>
							<ul class="site-footer-socials">
								<li>
									<a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer">
										<span class="site-footer-social-icon" aria-hidden="true">in</span>
										<span>mindstatebinauralbeatstudio</span>
									</a>
								</li>
								<li>
									<a href="https://www.instagram.com/mindstatesoundtherapy/" target="_blank" rel="noopener noreferrer">
										<span class="site-footer-social-icon" aria-hidden="true">
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
												<rect x="4" y="4" width="16" height="16" rx="5"></rect>
												<circle cx="12" cy="12" r="3.5"></circle>
												<circle cx="17" cy="7" r="0.8" fill="currentColor" stroke="none"></circle>
											</svg>
										</span>
										<span>@mindstatesoundtherapy</span>
									</a>
								</li>
							</ul>
						</div>
					</div>
				</div>

				<div class="site-footer-copyright">
					<p>© 2026 MindStateLab BV. All rights reserved. App & web development by michielroos.com. Graphic app & web design by vormgraaf.nl.</p>
				</div>
			</div>
		</footer>

		<script>
			// Mobile menu toggle
			document.addEventListener('DOMContentLoaded', () => {
				const menuToggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement | null;
				const mobileMenu = document.getElementById('mobile-menu');
				const siteNav = document.querySelector('.site-nav--hero');

				if (siteNav) {
					const updateNavState = () => {
						siteNav.classList.toggle('site-nav--scrolled', window.scrollY > 24);
					};

					updateNavState();
					window.addEventListener('scroll', updateNavState, { passive: true });
				}
				
				if (menuToggle && mobileMenu) {
					menuToggle.addEventListener('change', (e) => {
						const target = e.target as HTMLInputElement;
						if (target && target.checked) {
							mobileMenu.classList.remove('hidden');
							mobileMenu.style.display = 'block';
						} else {
							mobileMenu.classList.add('hidden');
							mobileMenu.style.display = 'none';
						}
					});
					
					// Close menu when clicking on a link
					const menuLinks = mobileMenu.querySelectorAll('a');
					menuLinks.forEach(link => {
						link.addEventListener('click', () => {
							if (menuToggle) {
								menuToggle.checked = false;
								mobileMenu.classList.add('hidden');
								mobileMenu.style.display = 'none';
							}
						});
					});
				}
			});
		</script>
		<style>
			.nav-shell {
				background: rgba(255, 247, 240, 0.86);
				border: 1px solid var(--border-light);
				border-radius: 999px;
				box-shadow: var(--shadow-soft);
				backdrop-filter: blur(18px);
			}

			.nav-links .nav-link {
				font-size: 0.875rem;
				font-weight: 600;
			}

			.nav-link {
				color: var(--text-secondary);
			}

			.nav-link:hover {
				color: var(--accent);
			}

			.site-logo-image {
				display: block;
				height: clamp(2.2rem, 2.1vw, 2.75rem);
				object-fit: contain;
				width: clamp(14rem, 18vw, 21rem);
			}

			.site-logo-mark {
				display: block;
				height: clamp(1.8rem, 2vw, 2.25rem);
				object-fit: contain;
				width: clamp(1.8rem, 2vw, 2.25rem);
			}

			.site-logo-wordmark {
				align-items: baseline;
				color: rgba(255, 255, 255, 0.88);
				display: inline-flex;
				font-family: var(--font-body);
				font-size: clamp(1.05rem, 0.9rem + 0.35vw, 1.28rem);
				font-weight: var(--font-weight-ui);
				gap: 0.28rem;
				line-height: 1;
				text-shadow: 0 1px 10px rgba(0, 0, 0, 0.16);
				white-space: nowrap;
			}

			.site-logo-name {
				font-weight: var(--font-weight-card-title);
			}

			.site-logo-divider,
			.site-logo-product {
				color: rgba(255, 255, 255, 0.78);
				font-weight: var(--font-weight-ui);
			}

			.site-nav--hero .nav-shell {
				background: transparent;
				border-color: transparent;
				box-shadow: none;
				backdrop-filter: none;
				padding-inline: 0;
				transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, padding-inline 0.2s ease;
			}

			.site-nav--hero.site-nav--scrolled .nav-shell,
			.site-nav--hero.site-nav--solid .nav-shell {
				background: rgba(34, 12, 18, 0.72);
				border-color: rgba(255, 255, 255, 0.16);
				box-shadow: 0 18px 50px rgba(0, 0, 0, 0.24);
				backdrop-filter: blur(18px);
				padding-inline: 1rem;
			}

			.site-nav--hero .nav-links {
				gap: clamp(1rem, 0.75rem + 0.45vw, 1.45rem);
			}

			.site-nav--hero .nav-link {
				color: rgba(255, 255, 255, 0.82);
				font-family: var(--font-body);
				font-size: clamp(1.05rem, 0.9rem + 0.35vw, 1.28rem);
				font-weight: var(--font-weight-ui);
				line-height: 1.05;
				text-shadow: 0 1px 10px rgba(0, 0, 0, 0.16);
			}

			.site-nav--hero .nav-link:hover {
				color: #ffffff;
			}

			.site-nav--hero .nav-download {
				background: linear-gradient(90deg, #0796a7 0%, #31bed0 100%);
				box-shadow: 0 10px 28px rgba(0, 0, 0, 0.2);
				color: #ffffff;
				font-family: var(--font-body);
				font-size: clamp(1rem, 0.9rem + 0.2vw, 1.15rem);
				font-weight: var(--font-weight-card-title);
				padding: 0.62rem 1.2rem;
			}

			.site-nav--hero .nav-download:hover {
				opacity: 1;
				transform: translateY(-1px);
			}

			.nav-menu-toggle--hero {
				color: rgba(255, 255, 255, 0.9);
			}

			.site-footer {
				--site-footer-heading: #ffffff;
				--site-footer-text: rgba(255, 255, 255, 0.72);
				--site-footer-muted: rgba(255, 255, 255, 0.6);
				--site-footer-social-bg: rgba(255, 255, 255, 0.92);
				--site-footer-social-color: #e85d00;
				background:
					radial-gradient(circle at 20% 48%, rgba(255, 255, 255, 0.12), transparent 14rem),
					linear-gradient(135deg, #ef6a00 0%, #e95e00 48%, #da5200 100%);
				min-height: 28rem;
				overflow: hidden;
				position: relative;
			}

			.site-footer-wave {
				background-image: url("data:image/svg+xml,%3Csvg width='900' height='320' viewBox='0 0 900 320' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='white' stroke-opacity='.32' stroke-width='1'%3E%3Cpath d='M-70 215C45 120 145 120 245 215S445 310 565 185 760 75 970 175'/%3E%3Cpath d='M-70 225C45 130 145 130 245 225S445 320 565 195 760 85 970 185'/%3E%3Cpath d='M-70 235C45 140 145 140 245 235S445 330 565 205 760 95 970 195'/%3E%3Cpath d='M-70 245C45 150 145 150 245 245S445 340 565 215 760 105 970 205'/%3E%3Cpath d='M-70 255C45 160 145 160 245 255S445 350 565 225 760 115 970 215'/%3E%3Cpath d='M-70 265C45 170 145 170 245 265S445 360 565 235 760 125 970 225'/%3E%3Cpath d='M-70 275C45 180 145 180 245 275S445 370 565 245 760 135 970 235'/%3E%3Cpath d='M-70 285C45 190 145 190 245 285S445 380 565 255 760 145 970 245'/%3E%3Cpath d='M-70 295C45 200 145 200 245 295S445 390 565 265 760 155 970 255'/%3E%3Cpath d='M-70 305C45 210 145 210 245 305S445 400 565 275 760 165 970 265'/%3E%3C/g%3E%3C/svg%3E");
				background-position: center;
				background-repeat: no-repeat;
				background-size: min(82rem, 126vw) auto;
				height: 100%;
				inset: 0;
				opacity: 0.24;
				position: absolute;
			}

			.site-footer-badge {
				align-items: center;
				border: 1px solid rgba(255, 255, 255, 0.68);
				border-radius: 999px;
				display: flex;
				font-family: var(--font-display);
				font-size: clamp(2rem, 1.6rem + 1vw, 2.8rem);
				font-weight: var(--font-weight-display);
				height: 7.5rem;
				justify-content: center;
				line-height: 0.8;
				position: absolute;
				right: clamp(2rem, 8vw, 7rem);
				text-align: center;
				top: 4rem;
				width: 7.5rem;
				z-index: 1;
			}

			.site-footer-inner {
				padding-bottom: 1.6rem;
				padding-top: 11rem;
				position: relative;
				z-index: 2;
			}

			.site-footer-grid {
				align-items: start;
				display: grid;
				gap: clamp(2rem, 5vw, 5rem);
				grid-template-columns: minmax(16rem, 1.15fr) minmax(9rem, 0.8fr) minmax(18rem, 1.45fr);
			}

			.site-footer-logo {
				align-items: center;
				color: var(--site-footer-heading);
				display: inline-flex;
				gap: 0.55rem;
				margin-bottom: 2rem;
			}

			.site-footer-logo-icon {
				display: block;
				height: clamp(1.9rem, 1.5rem + 1vw, 2.5rem);
				object-fit: contain;
				width: clamp(1.9rem, 1.5rem + 1vw, 2.5rem);
			}

			.site-footer-wordmark {
				align-items: baseline;
				display: inline-flex;
				flex-wrap: wrap;
				font-family: var(--font-body);
				gap: 0.28rem;
				line-height: 1;
			}

			.site-footer-logo-title {
				font-size: clamp(1.05rem, 0.9rem + 0.35vw, 1.28rem);
